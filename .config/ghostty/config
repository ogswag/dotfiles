font-family = "Menlo"
font-thicken = true
font-thicken-strength = 10
# font-style = "Medium"
font-size = 12

# theme = Material Darker
theme = light:Monokai Pro Light Sun,dark:Catppuccin Mocha
# background-opacity = 0.9
# macos-titlebar-style = native
macos-icon = custom-style
macos-icon-ghost-color = #ffffff
macos-icon-screen-color = #111111
macos-icon-frame = chrome

cursor-style = block
cursor-color = #FB9912
cursor-text = #190F01
shell-integration-features = no-cursor,ssh-terminfo,sudo,title

# window-inherit-font-size = false
window-height = 27
window-width= 92
